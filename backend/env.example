# Variables d'environnement pour Les Échos D'IEG Backend

# Port du serveur
PORT=5000

# MongoDB Atlas Connection String
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/les-echos-ieg?retryWrites=true&w=majority

# Alternative: MongoDB Local
# MONGO_URI=mongodb://localhost:27017/les-echos-ieg

# JWT Secret Key (générez une clé secrète forte)
JWT_SECRET=votre_super_cle_secrete_jwt_tres_longue_et_securisee_123456789

# JWT Expiration
JWT_EXPIRE=7d

# URL du frontend (pour CORS)
FRONTEND_URL=http://localhost:5173

# Environnement
NODE_ENV=development
